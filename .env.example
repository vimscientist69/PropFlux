SCRAPER_DEV_LIMIT=3
SCRAPER_HEADLESS=true
SCRAPER_ENV=debug
NOPECHA_API_KEY=
# Proxy Configuration (DataImpulse recommended)
# Rotating URL for Scrapy (e.g. http://user:pass@gw.dataimpulse.com:823)
ROTATING_PROXY_URL=
# Sticky URL for Selenium (Same host, but used for sticky sessions)
STICKY_PROXY_URL=
http://your_proxy_url

# Export Configuration
SCRAPER_EXPORT_BATCH_SIZE=100

# Concurrency Configuration
SCRAPER_MAX_CONCURRENT_BROWSERS=2

# Pagination retry backoff (search/result pages only)
SCRAPER_PAGINATION_RETRY_STEP_SECONDS=23
SCRAPER_PAGINATION_RETRY_MAX_SECONDS=813
SCRAPER_PAGINATION_RETRY_JITTER_PERCENT=35